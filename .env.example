# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI Configuration
VITE_OPENAI_API_KEY=your_openai_api_key
VITE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VITE_OPENAI_CHAT_MODEL=gpt-4o

# Langfuse Observability
VITE_LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
VITE_LANGFUSE_SECRET_KEY=your_langfuse_secret_key
VITE_LANGFUSE_HOST=https://cloud.langfuse.com

# Application Settings
VITE_DEV_MODE=true
VITE_ENABLE_RAG_DEBUG=true
